PORT=3000
CORS_ORIGIN=http://localhost:3001
# Chạy Nest trên máy (npm run start:dev): localhost. Docker Compose ghi đè thành service `postgres`.
DB_HOST=localhost
DB_PORT=5432
DB_USER=voz
DB_PASSWORD=voz
DB_NAME=voz_clone
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
# Redis (CacheModule). Chạy Nest trên máy: localhost. Docker Compose ghi đè thành service `redis`.
REDIS_HOST=localhost
REDIS_PORT=6379
FRONTEND_URL=http://localhost:3000
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@example.com
